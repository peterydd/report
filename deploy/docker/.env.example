# Production environment variables for the report CLI.
# 生产环境变量模板；复制为 .env 并填入真实值，.env 不入仓。
#
# docker compose 会自动加载本目录的 .env 文件。
# All values are read via viper's REPORT_* env overrides.

# --- SMTP / 邮件发送 ---
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=reports@example.com
# Use a dedicated app password / SMTP auth token, never a personal password.
# 使用专用应用密码 / SMTP 授权码，绝不使用个人账户密码。
SMTP_PASSWORD=replace-me-with-app-password
# Keep TLS verification on in production. Only set to true for self-signed test servers.
# 生产环境保持 TLS 证书校验开启；自签测试服务器才置 true。
SMTP_INSECURESKIPVERIFY=false
SMTP_TIMEOUT=30s

# --- Database / 数据库 ---
DB_DRIVER=mysql
# Format: user:password@tcp(host:port)/dbname?parseTime=true
DB_SOURCE=report:dbpassword@tcp(db.example.com:3306)/reportdb?parseTime=true&charset=utf8mb4
DB_MAXOPENCONNS=10
DB_MAXIDLECONNS=5
DB_CONNMAXLIFETIME=3m

# --- Misc / 其他 ---
TZ=Asia/Shanghai
