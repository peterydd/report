database:
  driver: "oracle"           # 支持: "oracle", "mysql", "postgresql", "clickhouse"
  source: "oracle://test:password@127.0.0.1:1521/FREEPDB1"
  maxOpenConns: 25           # 最大打开连接数
  maxIdleConns: 5            # 最大空闲连接数
  connMaxLifetime: "3m"      # 连接最大生命周期
smtp:
  host: "smtp.example.com"
  port: "25"
  username: "test@example.com"
  password: "password"       # 推荐改用 REPORT_SMTP_PASSWORD 环境变量，避免明文落盘
  insecureSkipVerify: false  # 是否跳过TLS证书验证，生产环境建议设为false
  timeout: "30s"             # SMTP操作超时时间
# 所有字段都可以通过 REPORT_<PATH> 形式的环境变量覆盖（点号转下划线）
# All fields can be overridden by REPORT_<PATH> env vars (dots become underscores)
# 例如: REPORT_SMTP_PASSWORD=xxx REPORT_SMTP_HOST=smtp.real.com
reports:
  - name: "报表名称"
    workBook:
      prefix: "报表名称_"
      dateFormat: "20060102150405"
      suffix: ".xlsx"
    sheets:
      - name: "sheet页1"
        sql: "select col1,col2,col3,col4,col5 from table1"
        column: "字段1,字段2,字段3,字段4,字段5"
        isSum: false
        sumBeginColumn: 0
        enableStream: false     # 是否启用流式查询（大数据量时建议开启）
        batchSize: 10000        # 流式查询批次大小（默认10000）
      - name: "sheet页2"
        sql: "select col1,col2,col3,col4,col5 from table2"
        column: "字段1,字段2,字段3,字段4,字段5"
        isSum: true
        sumBeginColumn: 3
        enableStream: true      # 启用流式查询处理大数据量
        batchSize: 50000        # 大数据量时可增大批次
    message:
      from: "test@example.com"
      to: ["test@outlook.com", "test@qq.com"]
      cc: ["test@gmail.com"]
      bcc: ["test@189.cn"]
      subject: "test主题"
      body: |
        test正文
            测试邮件，请查收附件
      contentType: "text/plain;charset=utf-8"
      attachment:
        contentType: "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet"
        withFile: true